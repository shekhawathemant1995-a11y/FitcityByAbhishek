{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "A gym member's profile and attendance data.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the member." },
        "uid": { "type": "string", "description": "Firebase Auth UID linked to this member." },
        "name": { "type": "string", "description": "Full name of the member." },
        "phone": { "type": "string", "description": "Contact phone number." },
        "email": { "type": "string", "description": "Email address." },
        "joinDate": { "type": "string", "format": "date", "description": "Date the member joined (YYYY-MM-DD)." },
        "expiryDate": { "type": "string", "format": "date", "description": "Date the membership expires (YYYY-MM-DD)." },
        "plan": { "type": "string", "description": "The membership plan name." },
        "status": { "type": "string", "enum": ["Active", "Expired", "Pending"], "description": "Current membership status." },
        "amountPaid": { "type": "number", "description": "Total amount paid for the current plan." },
        "attendance": { 
          "type": "object", 
          "description": "Record of attendance where keys are dates (YYYY-MM-DD) and values are booleans."
        }
      },
      "required": ["id", "name", "phone", "joinDate", "expiryDate", "plan", "status", "amountPaid"]
    },
    "Progress": {
      "title": "Progress",
      "description": "Member's physical progress tracking.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "weight": { "type": "number" },
        "measurements": {
          "type": "object",
          "properties": {
            "chest": { "type": "number" },
            "waist": { "type": "number" },
            "hips": { "type": "number" },
            "arms": { "type": "number" }
          }
        }
      },
      "required": ["uid", "date", "weight"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Membership payment history.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "amount": { "type": "number" },
        "plan": { "type": "string" },
        "status": { "type": "string", "enum": ["Success", "Pending", "Failed"] }
      },
      "required": ["uid", "date", "amount", "plan", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notifications for members.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["Renewal", "Workout", "Offer", "System"] },
        "date": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["uid", "title", "message", "type", "date", "read"]
    },
    "Workout": {
      "title": "Workout",
      "description": "Daily workout plans.",
      "type": "object",
      "properties": {
        "day": { "type": "string", "description": "Day of the week (Monday, etc.)" },
        "title": { "type": "string" },
        "exercises": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "sets": { "type": "number" },
              "reps": { "type": "string" }
            }
          }
        }
      },
      "required": ["day", "title", "exercises"]
    },
    "User": {
      "title": "User",
      "description": "Application user with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID." },
        "email": { "type": "string", "description": "User's email address." },
        "role": { "type": "string", "enum": ["admin", "staff"], "description": "Access role." },
        "displayName": { "type": "string", "description": "User's display name." },
        "phone": { "type": "string", "description": "User's phone number." },
        "location": { "type": "string", "description": "User's location." }
      },
      "required": ["uid", "email", "role"]
    },
    "Log": {
      "title": "Log",
      "description": "System activity logs.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["MemberAdded", "MemberUpdated", "PlanUpdated", "ProfileUpdated", "MembershipRequested"] },
        "message": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "adminId": { "type": "string" }
      },
      "required": ["type", "message", "date"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Gym announcements.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "content", "date", "authorId"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of gym members."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of application users for RBAC."
    },
    "/progress/{progressId}": {
      "schema": "Progress",
      "description": "Member progress records."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Membership payment records."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Member notifications."
    },
    "/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Daily workout plans."
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "System activity logs."
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Gym announcements."
    }
  }
}
